		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"electron": "^41.0.3",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.1.0",
